# Get a free DeepL API key at https://www.deepl.com/pro-api (free tier, no credit card charge)
# Copy this file to ".env" and paste your key below.
DEEPL_API_KEY=your-deepl-api-key-here

# Free-tier DeepL keys end in ":fx" and use the api-free.deepl.com host.
# If you ever upgrade to a paid DeepL plan, change this to https://api.deepl.com
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

# Only needed when deploying to the cloud (e.g. Render). Get these by creating a
# free database at https://turso.tech ("turso db create german-vocab", then
# "turso db show german-vocab --url" and "turso db tokens create german-vocab").
# Leave both unset for local development — the app then just uses a local
# SQLite file at data/words.db instead.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Any long random string — used to sign login session cookies. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
